# --- Local development ---
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/easyshop
JWT_SECRET=change-this-to-a-long-random-string-in-production
NODE_ENV=development
# Comma-separated browser origins allowed to call the API with credentials
CLIENT_URL=http://localhost:5173

# --- Production (Render) ---
# PORT is set automatically by Render
# NODE_ENV=production
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/easyshop
# JWT_SECRET=use-a-strong-secret-at-least-32-chars
# CLIENT_URL=https://your-app.vercel.app,https://www.your-domain.com
# VERCEL_URL is optionally auto-detected in some preview integrations
