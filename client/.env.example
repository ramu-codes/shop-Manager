# Local development (Vite dev server)
# Leave VITE_API_URL empty so the browser calls /api/... on :5173 and Vite proxies to the backend.
VITE_API_URL=

# Optional: override proxy target if the API is not on localhost:5000 (see vite.config.js)
# VITE_DEV_PROXY_TARGET=http://localhost:5000

# --- Production (Vercel) ---
# Set in Vercel Project → Settings → Environment Variables.
# Use your Render service origin only (no trailing slash, no /api suffix).
# The client always requests /api/... on that host.
# Example:
# VITE_API_URL=https://easyshop-api-xxxx.onrender.com
#
# If you previously set http://localhost:5000/api, remove the /api part or the
# app will normalize it — paths already include /api.
#
# Security note:
# Never store private secrets in frontend env vars. Any VITE_* variable is public.
